{
  "name": "ai-interviewer",
  "version": "1.0.0",
  "description": "AI-powered live coding interview platform",
  "main": "backend/src/index.js",
  "scripts": {
    "dev": "concurrently \"npm --prefix backend run dev\" \"npm --prefix frontend run dev\"",
    "build": "npm --prefix frontend run build",
    "start": "npm --prefix backend run start",
    "install-all": "npm install && npm --prefix backend install && npm --prefix frontend install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": [
    "ai",
    "interview",
    "coding",
    "real-time",
    "assessment"
  ],
  "author": "CodeSage Team",
  "license": "MIT"
}